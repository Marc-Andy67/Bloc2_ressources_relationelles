{% extends 'base.html.twig' %}

{% block title %}S'inscrire - (RE)Sources Relationnelles{% endblock %}

{% block body %}
<div class="flex-grow flex items-center justify-center p-4">
    <div class="glass-card w-full max-w-md p-8 md:p-10 relative overflow-hidden">
        
        {# Decorative background element inside the card #}
        <div class="absolute -bottom-24 -left-24 w-48 h-48 bg-secondary/10 rounded-full blur-3xl pointer-events-none"></div>

        <div class="text-center mb-8 relative z-10">
            <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight">Créer un compte</h1>
            <p class="text-slate-900 dark:text-white mt-2">Rejoignez la communauté en quelques instants</p>
        </div>

        {% if not registrationForm.vars.valid %}
            <div class="p-4 mb-6 rounded-lg bg-red-50 border border-red-200 text-red-700 text-sm">
                {{ form_errors(registrationForm) }}
            </div>
        {% endif %}

        {{ form_start(registrationForm, {'attr': {'class': 'space-y-5 relative z-10'}}) }}
            
            <div>
                {{ form_label(registrationForm.name, 'Nom complet', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(registrationForm.name, {'attr': {'class': 'input-field', 'placeholder': 'John Doe'}}) }}
                <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.name) }}</div>
            </div>

            <div>
                {{ form_label(registrationForm.email, 'Adresse Email', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(registrationForm.email, {'attr': {'class': 'input-field', 'placeholder': 'vous@exemple.com'}}) }}
                <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.email) }}</div>
            </div>

            <div>
                {{ form_label(registrationForm.plainPassword, 'Mot de passe', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(registrationForm.plainPassword, {'attr': {'class': 'input-field', 'placeholder': '••••••••'}}) }}
                <div class="text-red-500 text-xs mt-1">{{ form_errors(registrationForm.plainPassword) }}</div>
            </div>

            <div id="password-rules" class="bg-slate-50/80 dark:bg-slate-800/80 p-4 rounded-lg border border-slate-200 dark:border-slate-700 mt-2 text-xs text-slate-900 dark:text-white">
                <p class="font-semibold mb-2 text-slate-900 dark:text-white">Sécurité du mot de passe :</p>
                <ul class="space-y-1.5 list-none m-0 p-0">
                    <li id="rule-length" class="flex items-center gap-2 text-slate-900 transition-colors duration-300 dark:text-white">
                        <span class="icon-wrapper">{{ ux_icon('heroicons:minus', {class: 'w-4 h-4'}) }}</span> <span>Au moins 12 caractères</span>
                    </li>
                    <li id="rule-uppercase" class="flex items-center gap-2 text-slate-900 transition-colors duration-300 dark:text-white">
                        <span class="icon-wrapper">{{ ux_icon('heroicons:minus', {class: 'w-4 h-4'}) }}</span> <span>Au moins une majuscule</span>
                    </li>
                    <li id="rule-lowercase" class="flex items-center gap-2 text-slate-900 transition-colors duration-300 dark:text-white">
                        <span class="icon-wrapper">{{ ux_icon('heroicons:minus', {class: 'w-4 h-4'}) }}</span> <span>Au moins une minuscule</span>
                    </li>
                    <li id="rule-number" class="flex items-center gap-2 text-slate-900 transition-colors duration-300 dark:text-white">
                        <span class="icon-wrapper">{{ ux_icon('heroicons:minus', {class: 'w-4 h-4'}) }}</span> <span>Au moins un chiffre</span>
                    </li>
                    <li id="rule-special" class="flex items-center gap-2 text-slate-900 transition-colors duration-300 dark:text-white">
                        <span class="icon-wrapper">{{ ux_icon('heroicons:minus', {class: 'w-4 h-4'}) }}</span> <span>Au moins un caractère spécial</span>
                    </li>
                </ul>
            </div>

            <div class="flex items-center mt-4">
                {{ form_widget(registrationForm.agreeTerms, {'attr': {'class': 'w-4 h-4 text-primary bg-white border-slate-300 rounded focus:ring-primary focus:ring-2 dark:bg-slate-800 dark:border-slate-600'}}) }}
                {{ form_label(registrationForm.agreeTerms, "J'accepte les conditions d'utilisation", {'label_attr': {'class': 'ml-2 text-sm text-slate-900 dark:text-white font-medium'}}) }}
            </div>

            <div class="pt-4">
                <button type="submit" class="btn-primary w-full flex justify-center items-center gap-2">
                    Créer mon compte
                    {{ ux_icon('heroicons:user-plus', {class: 'w-5 h-5'}) }}
                </button>
            </div>
            
            <div class="text-center mt-6 text-sm text-slate-900 dark:text-white">
                Vous avez déjà un compte ? 
                <a href="{{ path('app_login') }}" class="font-semibold text-primary dark:text-blue-400 hover:text-indigo-700 dark:hover:text-blue-300 transition-colors">Se connecter</a>
            </div>

        {{ form_end(registrationForm) }}

    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        const passwordField = document.getElementById('registration_form_plainPassword');
        if (passwordField) {
            const rules = {
                length: /.{12,}/,
                uppercase: /[A-Z]/,
                lowercase: /[a-z]/,
                number: /\d/,
                special: /[\W_]/
            };

            const successIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>`;
            const pendingIcon = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-4 h-4"><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 12h-15" /></svg>`;

            passwordField.addEventListener('input', function() {
                const val = this.value;
                for (const [key, regex] of Object.entries(rules)) {
                    const el = document.getElementById('rule-' + key);
                    if (el) {
                        const iconContainer = el.querySelector('.icon-wrapper');
                        if (regex.test(val)) {
                            el.classList.remove('text-slate-700');
                            el.classList.add('text-emerald-500');
                            if(iconContainer) iconContainer.innerHTML = successIcon;
                        } else {
                            el.classList.remove('text-emerald-500');
                            el.classList.add('text-slate-700');
                            if(iconContainer) iconContainer.innerHTML = pendingIcon;
                        }
                    }
                }
            });
            // Initial check
            passwordField.dispatchEvent(new Event('input'));
        }
    });
</script>
{% endblock %}
