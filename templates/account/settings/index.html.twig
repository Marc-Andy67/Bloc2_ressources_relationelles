{% extends 'base.html.twig' %}

{% block title %}Paramètres{% endblock %}

{% block body %}

<div class="w-full px-16 py-12">

    <h1 class="text-3xl font-bold text-slate-900 dark:text-white mb-10">
        Paramètres du compte
    </h1>

    <div class="flex gap-16 items-start">

        {# SIDEBAR 30% #}
        <aside class="w-[30%]">

            <nav class="bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-2xl p-3 space-y-2 shadow-sm">

                <button
                    data-tab="password"
                    class="settings-tab w-full flex items-center gap-4 px-5 py-4 rounded-xl text-base font-semibold text-slate-800 dark:text-white hover:bg-blue-50 dark:hover:bg-blue-900/40 transition">

                    {{ ux_icon('heroicons:key', {class: 'w-6 h-6 text-blue-600'}) }}

                    Mot de passe
                </button>

                <button
                    data-tab="delete"
                    class="settings-tab w-full flex items-center gap-4 px-5 py-4 rounded-xl text-base font-semibold text-slate-800 dark:text-white hover:bg-red-50 dark:hover:bg-red-900/40 transition">

                    {{ ux_icon('heroicons:trash', {class: 'w-6 h-6 text-red-600'}) }}

                    Supprimer le compte
                </button>

            </nav>

        </aside>


        {# CONTENU 60% #}
        <section class="w-[60%]">

            <div id="tab-password" class="settings-panel">
                {% include "account/settings/sections/change_password.html.twig" %}
            </div>

            <div id="tab-delete" class="settings-panel hidden">
                {% include "account/settings/sections/delete_account.html.twig" %}
            </div>

        </section>

    </div>

</div>

<script>
document.querySelectorAll(".settings-tab").forEach(tab => {

    tab.addEventListener("click", () => {

        let target = tab.dataset.tab;

        document.querySelectorAll(".settings-panel").forEach(panel => {
            panel.classList.add("hidden");
        });

        document.querySelector("#tab-" + target).classList.remove("hidden");

    });

});
</script>

{% endblock %}