<div class="bg-white dark:bg-slate-950 border border-slate-200 dark:border-slate-800 rounded-2xl p-8 shadow-sm space-y-6">

    <div>
        <h2 class="text-lg font-semibold text-slate-900 dark:text-white">
            Modifier le mot de passe
        </h2>

        <p class="text-sm text-slate-500">
            Choisissez un mot de passe sécurisé.
        </p>
    </div>

    {{ form_start(passwordForm) }}

    <div class="space-y-6">

        <div>
            {{ form_label(passwordForm.currentPassword, null, {
                label_attr: {class: "block mb-1 font-medium text-slate-700 dark:text-slate-300"}
            }) }}

            {{ form_widget(passwordForm.currentPassword, {
                attr: {
                    class: "w-full px-4 py-2 border border-slate-300 rounded-lg bg-white text-slate-900 dark:bg-slate-900 dark:border-slate-700 dark:text-white"
                }
            }) }}
        </div>

        <div>
            {{ form_label(passwordForm.newPassword.first) }}

            {{ form_widget(passwordForm.newPassword.first, {
                attr: {
                    class: "w-full px-4 py-2 border border-slate-300 rounded-lg bg-white text-slate-900 dark:bg-slate-900 dark:border-slate-700 dark:text-white"
                }
            }) }}
        </div>

        <div>
            {{ form_label(passwordForm.newPassword.second) }}

            {{ form_widget(passwordForm.newPassword.second, {
                attr: {
                    class: "w-full px-4 py-2 border border-slate-300 rounded-lg bg-white text-slate-900 dark:bg-slate-900 dark:border-slate-700 dark:text-white"
                }
            }) }}
        </div>

        <button class="mt-4 px-5 py-2.5 rounded-lg bg-blue-600 hover:bg-blue-700 text-black font-semibold transition">
            Mettre à jour le mot de passe
        </button>

    </div>

    {{ form_end(passwordForm) }}

</div>