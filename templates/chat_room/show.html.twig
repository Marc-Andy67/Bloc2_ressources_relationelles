{% extends 'base.html.twig' %}

{% block title %}{{ chat_room.name }} — Discussion — (RE)Sources Relationnelles{% endblock %}

{% block body %}
<div class="max-w-4xl mx-auto flex flex-col gap-6 pb-12">

    {# Salon header #}
    <div class="flex items-center justify-between border-b border-slate-200 pb-5">
        <div>
            <h1 class="text-2xl font-extrabold text-slate-900 flex items-center gap-3 dark:text-white">
                {{ ux_icon('heroicons:chat-bubble-left-right', {class: 'w-7 h-7 text-primary'}) }}
                {{ chat_room.name }}
            </h1>
            {% if chat_room.ressource %}
            <p class="text-slate-900 mt-1 text-sm dark:text-white">
                Discussion liée à la ressource :
                <a href="{{ path('app_ressource_show', {'id': chat_room.ressource.id}) }}" class="font-semibold text-primary hover:underline">
                    {{ chat_room.ressource.title }}
                </a>
            </p>
            {% endif %}
        </div>
        <div class="flex items-center gap-3 text-xs text-slate-900 font-medium dark:text-white">
            {{ ux_icon('heroicons:users', {class: 'w-4 h-4'}) }}
            {{ chat_room.members|length }} membre{{ chat_room.members|length != 1 ? 's' }}
        </div>
    </div>

    {# Messages thread #}
    <div class="glass-card border border-slate-200/60 flex flex-col relative overflow-hidden" style="min-height: 400px;">
        <div class="absolute inset-0 bg-gradient-to-br from-transparent to-primary/5 pointer-events-none"></div>
        
        <div {{ turbo_stream_listen('chat_room_' ~ chat_room.id) }}></div>
        
        <div class="p-5 flex-grow flex flex-col gap-5 overflow-y-auto relative z-10" id="messages-list">
            {% if chat_room.messages is defined and chat_room.messages|length > 0 %}
                {% for message in chat_room.messages %}
                    {% include 'chat_room/_message.html.twig' %}
                {% endfor %}
            {% else %}
                <div class="flex-grow flex flex-col items-center justify-center text-center py-10 text-slate-500 dark:text-slate-400">
                    <div class="w-16 h-16 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center mb-4">
                        {{ ux_icon('heroicons:chat-bubble-left-ellipsis', {class: 'w-8 h-8 opacity-70'}) }}
                    </div>
                    <p class="font-medium text-slate-700 dark:text-slate-300">Aucun message pour l'instant.</p>
                    <p class="text-sm mt-1">Soyez le premier à contribuer à cette discussion !</p>
                </div>
            {% endif %}
        </div>

        {# Message form #}
        {% if app.user %}
        <div class="border-t border-slate-100 dark:border-slate-800 bg-white/50 dark:bg-slate-900/50 rounded-b-xl overflow-hidden relative z-20">
            {% include 'chat_room/_message_form.html.twig' %}
        </div>
        {% else %}
        <div class="border-t border-slate-100 p-4 text-center text-sm text-slate-900 dark:text-white">
            <a href="{{ path('app_login') }}" class="font-semibold text-primary hover:underline">Connectez-vous</a> pour participer à la discussion.
        </div>
        {% endif %}
    </div>

    <a href="{{ path('app_chat_room_index') }}" class="text-sm text-slate-900 hover:text-slate-900 flex items-center gap-1 self-start dark:text-white">
        {{ ux_icon('heroicons:arrow-left', {class: 'w-4 h-4'}) }}
        Retour aux discussions
    </a>
</div>
{% endblock %}
