{% extends 'base.html.twig' %}

{% block title %}Demande d'accès — {{ chat_room.name }}{% endblock %}

{% block body %}
<!-- ------------------------------------------------------------------------------------------------------
HERO SECTION
------------------------------------------------------------------------------------------------------- -->
<section class="relative bg-gradient-to-br from-indigo-900 via-purple-900 to-indigo-900 text-white overflow-hidden pt-24 pb-16">
    <div class="absolute inset-0 bg-[url('https://www.transparenttextures.com/patterns/stardust.png')] opacity-30 mix-blend-overlay"></div>
    <div class="container mx-auto px-6 relative z-10 text-center">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4 tracking-tight">
            Accès au salon
        </h1>
        <p class="text-lg md:text-xl text-gray-200 max-w-3xl mx-auto">{{ chat_room.name }}</p>
    </div>
</section>

<div class="px-4 md:px-8 py-8 md:py-12 max-w-2xl mx-auto flex flex-col gap-8">
    <div class="glass-card flex flex-col items-center justify-center p-12 text-center">
        <div class="bg-indigo-100 dark:bg-indigo-900/50 p-6 rounded-full inline-block mb-6 shadow-md border-4 border-white dark:border-slate-800">
            {{ ux_icon('heroicons:lock-closed', {class: 'w-12 h-12 text-primary dark:text-blue-400'}) }}
        </div>
        <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-4">Salon privé</h2>
        <p class="text-slate-600 dark:text-slate-300 mb-8 max-w-md">
            Ce salon de discussion est limité. Vous devez faire une demande d'accès à l'hôte pour pouvoir y participer et voir les messages.
        </p>

        <form method="post" action="{{ path('app_chat_room_join_or_create', {id: chat_room.Ressource.id}) }}">
            <button type="submit" class="btn-primary flex items-center gap-2 group transform hover:scale-105 transition-all text-lg px-8 py-4">
                {{ ux_icon('heroicons:paper-airplane', {class: 'w-5 h-5 group-hover:-translate-y-1 group-hover:translate-x-1 transition-transform'}) }}
                Faire une demande d'accès
            </button>
        </form>
        
        <a href="{{ path('app_home') }}" class="mt-6 text-sm text-slate-500 hover:text-primary transition-colors underline underline-offset-4">
            Retour à l'accueil
        </a>
    </div>
</div>
{% endblock %}
