{% extends 'base.html.twig' %}

{% block title %}Mes Chatrooms — (RE)Sources Relationnelles{% endblock %}

{% block body %}
<div class="px-4 md:px-8 py-8 md:py-12 max-w-4xl mx-auto flex flex-col gap-8">

    <div class="flex justify-between items-end border-b border-slate-200 pb-5">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3 dark:text-white">
                {{ ux_icon('heroicons:chat-bubble-bottom-center-text', {class: 'w-8 h-8 text-primary'}) }}
                Mes Chatrooms
            </h1>
            <p class="text-slate-900 mt-2 dark:text-white">Retrouvez les salons de discussion que vous avez rejoints.</p>
        </div>
        <a href="{{ path('app_chat_room_index') }}" class="btn-secondary text-sm flex items-center gap-2">
            {{ ux_icon('heroicons:magnifying-glass', {class: 'w-4 h-4'}) }}
            Tous les salons
        </a>
    </div>

    {% if chat_rooms is empty %}
        <div class="glass-card flex flex-col items-center justify-center p-16 text-center border border-dashed border-slate-300">
            <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-4 text-slate-900 dark:text-white">
                {{ ux_icon('heroicons:inbox', {class: 'w-10 h-10'}) }}
            </div>
            <h2 class="text-xl font-bold text-slate-900 mb-2 dark:text-white">Vous n'avez rejoint aucun salon</h2>
            <p class="text-slate-900 max-w-md mx-auto mb-6 dark:text-white">
                Découvrez les ressources de type jeu et rejoignez leur discussion pour échanger avec la communauté.
            </p>
            <a href="{{ path('app_ressource_index') }}" class="btn-primary flex items-center gap-2">
                {{ ux_icon('heroicons:magnifying-glass', {class: 'w-5 h-5'}) }}
                Explorer les ressources
            </a>
        </div>
    {% else %}
        <ul class="flex flex-col gap-4">
            {% for chat_room in chat_rooms %}
                {% set last_message = chat_room.messages|last %}
                
                <li>
                    <a href="{{ path('app_chat_room_show', {'id': chat_room.id}) }}" class="glass-card flex items-start gap-5 p-5 border border-slate-200/60 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 ease-out group">
                        
                        <div class="w-14 h-14 rounded-2xl bg-gradient-to-br from-primary/20 to-primary/5 flex items-center justify-center shrink-0 shadow-inner">
                            {{ ux_icon('heroicons:chat-bubble-oval-left-ellipsis', {class: 'w-7 h-7 text-primary group-hover:scale-110 transition-transform duration-300'}) }}
                        </div>
                        
                        <div class="flex-grow min-w-0 flex flex-col justify-center">
                            <div class="flex justify-between items-start mb-1">
                                <h3 class="font-bold text-lg text-slate-900 group-hover:text-primary transition-colors dark:text-white truncate pr-4">
                                    {{ chat_room.name }}
                                </h3>
                                {% if last_message %}
                                    <span class="text-xs font-medium text-slate-500 whitespace-nowrap dark:text-slate-400 mt-1">
                                        {{ last_message.creationDate|date('d/m/Y H:i') }}
                                    </span>
                                {% endif %}
                            </div>
                            
                            {% if chat_room.ressource %}
                                <p class="text-xs font-medium text-slate-500 mb-2 flex items-center gap-1.5 dark:text-slate-400">
                                    {{ ux_icon('heroicons:link', {class: 'w-3.5 h-3.5'}) }}
                                    Ressource : {{ chat_room.ressource.title }}
                                </p>
                            {% endif %}
                            
                            <div class="bg-slate-50/50 dark:bg-slate-800/50 rounded-lg p-3 border border-slate-100 dark:border-slate-700/50">
                                {% if last_message %}
                                    <p class="text-sm text-slate-600 dark:text-slate-300 truncate">
                                        <span class="font-semibold text-slate-800 dark:text-slate-200">{{ last_message.author.userIdentifier }} :</span> 
                                        {{ last_message.content }}
                                    </p>
                                {% else %}
                                    <p class="text-sm text-slate-400 italic dark:text-slate-500">Aucun message pour le moment. Soyez le premier à écrire !</p>
                                {% endif %}
                            </div>
                        </div>
                        
                        <div class="flex items-center self-stretch justify-end pl-2">
                            <div class="w-8 h-8 rounded-full bg-primary flex items-center justify-center text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 shadow-md transform translate-x-4 group-hover:translate-x-0">
                                {{ ux_icon('heroicons:arrow-right', {class: 'w-4 h-4'}) }}
                            </div>
                        </div>
                    </a>
                </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}
