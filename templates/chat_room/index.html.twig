{% extends 'base.html.twig' %}

{% block title %}Conversations — (RE)Sources Relationnelles{% endblock %}

{% block body %}
<div class="px-4 md:px-8 py-8 md:py-12 max-w-4xl mx-auto flex flex-col gap-8">

    <div class="flex justify-between items-end border-b border-slate-200 pb-5">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3 dark:text-white">
                {{ ux_icon('heroicons:chat-bubble-left-right', {class: 'w-8 h-8 text-primary'}) }}
                Conversations
            </h1>
            <p class="text-slate-900 mt-2 dark:text-white">Rejoignez les discussions liées aux ressources de la plateforme.</p>
        </div>
    </div>

    {% if chat_rooms is empty %}
        <div class="glass-card flex flex-col items-center justify-center p-16 text-center border border-dashed border-slate-300">
            <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-4 text-slate-900 dark:text-white">
                {{ ux_icon('heroicons:chat-bubble-left-right', {class: 'w-10 h-10'}) }}
            </div>
            <h2 class="text-xl font-bold text-slate-900 mb-2 dark:text-white">Aucun salon disponible</h2>
            <p class="text-slate-900 max-w-md mx-auto dark:text-white">
                Les salons de discussion sont créés depuis les pages de ressources. Explorez une ressource et rejoignez sa discussion !
            </p>
            <a href="{{ path('app_ressource_index') }}" class="btn-primary mt-6 flex items-center gap-2">
                {{ ux_icon('heroicons:magnifying-glass', {class: 'w-5 h-5'}) }}
                Explorer les ressources
            </a>
        </div>
    {% else %}
        <ul class="flex flex-col gap-3">
            {% for chat_room in chat_rooms %}
            <li>
                <a href="{{ path('app_chat_room_show', {'id': chat_room.id}) }}" class="glass-card flex items-center gap-4 p-5 border border-slate-200/60 hover:shadow-lg hover:-translate-y-0.5 transition-all group">
                    <div class="w-12 h-12 rounded-xl bg-primary/10 flex items-center justify-center shrink-0">
                        {{ ux_icon('heroicons:chat-bubble-oval-left-ellipsis', {class: 'w-6 h-6 text-primary'}) }}
                    </div>
                    <div class="flex-grow min-w-0">
                        <p class="font-bold text-slate-900 group-hover:text-primary transition-colors dark:text-white">{{ chat_room.name }}</p>
                        {% if chat_room.ressource %}
                        <p class="text-xs text-slate-900 mt-0.5 truncate dark:text-white">
                            {{ ux_icon('heroicons:link', {class: 'w-3.5 h-3.5 inline mr-1'}) }}
                            {{ chat_room.ressource.title }}
                        </p>
                        {% endif %}
                    </div>
                    <div class="flex items-center gap-4 shrink-0">
                        <span class="flex items-center gap-1.5 text-xs text-slate-900 font-medium dark:text-white">
                            {{ ux_icon('heroicons:users', {class: 'w-4 h-4'}) }}
                            {{ chat_room.members|length }}
                        </span>
                        {{ ux_icon('heroicons:arrow-right', {class: 'w-5 h-5 text-slate-900 group-hover:text-primary transition-colors'}) }}
                    </div>
                </a>
            </li>
            {% endfor %}
        </ul>
    {% endif %}
</div>
{% endblock %}
