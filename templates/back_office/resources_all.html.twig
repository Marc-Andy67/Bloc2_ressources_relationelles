{% extends 'base.html.twig' %}

{% block title %}Back Office - Toutes les ressources{% endblock %}

{% block body %}
<div class="flex flex-col md:flex-row gap-8 w-full">
    <!-- Sidebar Navigation -->
    <aside class="w-full md:w-64 shrink-0 gsap-stagger-item">
        {% include 'back_office/_nav.html.twig' %}
    </aside>
    
    <!-- Main Content -->
    <div class="flex-1 min-w-0 flex flex-col gap-6">
        <div class="header-section gsap-stagger-item flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
            <div>
                <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 dark:text-white tracking-tight">Toutes les ressources</h1>
                <p class="text-slate-900 dark:text-white mt-2">Gérez l'ensemble des ressources publiées ou en attente sur la plateforme.</p>
            </div>
            <a href="{{ path('app_ressource_new') }}" class="btn-primary flex items-center gap-2">
                {{ ux_icon('heroicons:plus-circle', {class: 'w-5 h-5'}) }} Créer ressource
            </a>
        </div>

        {% for label, messages in app.flashes %}
            {% for message in messages %}
                <div class="gsap-stagger-item p-4 rounded-xl {% if label == 'success' %}bg-emerald-50 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-300 border-emerald-200 dark:border-emerald-800{% else %}bg-rose-50 text-rose-800 dark:bg-rose-900/30 dark:text-rose-300 border-rose-200 dark:border-rose-800{% endif %} border flex items-center gap-3 font-medium shadow-sm">
                    {{ ux_icon(label == 'success' ? 'heroicons:check-circle' : 'heroicons:exclamation-triangle', {class: 'w-5 h-5'}) }}
                    {{ message }}
                </div>
            {% endfor %}
        {% endfor %}

        <!-- Filters -->
        <div class="glass-card p-2 rounded-2xl flex flex-wrap gap-2 w-full gsap-stagger-item">
            <a href="{{ path('app_admin_resources') }}" class="px-4 py-2 rounded-xl text-sm font-bold transition-all {{ not current_status ? 'bg-primary text-white shadow-md' : 'text-slate-900 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-800' }}">Tous</a>
            <a href="{{ path('app_admin_resources', {'status': 'validated'}) }}" class="px-4 py-2 rounded-xl text-sm font-bold transition-all {{ current_status == 'validated' ? 'bg-emerald-500 text-white shadow-md' : 'text-slate-900 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-800' }}">Validées</a>
            <a href="{{ path('app_admin_resources', {'status': 'pending'}) }}" class="px-4 py-2 rounded-xl text-sm font-bold transition-all {{ current_status == 'pending' ? 'bg-amber-500 text-white shadow-md' : 'text-slate-900 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-800' }}">En attente</a>
            <a href="{{ path('app_admin_resources', {'status': 'selected'}) }}" class="px-4 py-2 rounded-xl text-sm font-bold transition-all {{ current_status == 'rejected' ? 'bg-rose-500 text-white shadow-md' : 'text-slate-900 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-800' }}">Refusées</a>
            <a href="{{ path('app_admin_resources', {'status': 'suspended'}) }}" class="px-4 py-2 rounded-xl text-sm font-bold transition-all {{ current_status == 'suspended' ? 'bg-slate-500 text-white shadow-md' : 'text-slate-900 dark:text-white hover:bg-slate-100 dark:hover:bg-slate-800' }}">Suspendues</a>
        </div>

        <div class="grid grid-cols-1 xl:grid-cols-2 gap-6 w-full">
            {% for ressource in resources %}
                <div class="glass-card flex flex-col h-full rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1 gsap-stagger-item group">
                    <div class="p-5 flex-1 flex flex-col relative z-10">
                        <div class="flex justify-between items-start mb-3 gap-2">
                            <h3 class="font-extrabold text-lg text-slate-900 dark:text-white line-clamp-1 group-hover:text-primary transition-colors">
                                {{ ressource.title }}
                            </h3>
                            {% if ressource.status == 'pending' %}
                                <span class="bg-amber-100 text-amber-800 dark:bg-amber-900/40 dark:text-amber-300 text-xs px-2.5 py-1 rounded-full font-bold uppercase tracking-wider whitespace-nowrap">Attente</span>
                            {% elseif ressource.status == 'validated' %}
                                <span class="bg-emerald-100 text-emerald-800 dark:bg-emerald-900/40 dark:text-emerald-300 text-xs px-2.5 py-1 rounded-full font-bold uppercase tracking-wider whitespace-nowrap">Publiée</span>
                            {% elseif ressource.status == 'rejected' %}
                                <span class="bg-rose-100 text-rose-800 dark:bg-rose-900/40 dark:text-rose-300 text-xs px-2.5 py-1 rounded-full font-bold uppercase tracking-wider whitespace-nowrap">Refusée</span>
                            {% elseif ressource.status == 'suspended' %}
                                <span class="bg-slate-100 text-slate-900 dark:bg-slate-800 dark:text-slate-100 text-xs px-2.5 py-1 rounded-full font-bold uppercase tracking-wider whitespace-nowrap">Suspendue</span>
                            {% endif %}
                        </div>
                        
                        <p class="text-slate-900 dark:text-white text-sm mb-4 line-clamp-2">
                            {{ ressource.content }}
                        </p>

                        <div class="mt-auto grid grid-cols-2 gap-2 text-xs font-semibold text-slate-900 dark:text-white mb-4 bg-slate-50 dark:bg-slate-800/50 rounded-xl p-3">
                            <div class="flex items-center gap-1.5 min-w-0">
                                {{ ux_icon('heroicons:user', {class: 'w-4 h-4 shrink-0'}) }}
                                <span class="truncate">{{ ressource.author.email }}</span>
                            </div>
                            <div class="flex items-center gap-1.5 min-w-0">
                                {{ ux_icon('heroicons:tag', {class: 'w-4 h-4 shrink-0'}) }}
                                <span class="truncate">{{ ressource.category.name }}</span>
                            </div>
                            <div class="flex items-center gap-1.5 min-w-0">
                                {{ ux_icon('heroicons:calendar', {class: 'w-4 h-4 shrink-0'}) }}
                                <span class="truncate">{{ ressource.creationDate|date('d/m/Y') }}</span>
                            </div>
                        </div>
                    </div>
                    
                    <div class="bg-slate-50/80 dark:bg-slate-800/80 p-3 flex justify-between items-center border-t border-slate-100 dark:border-slate-700/50">
                        <div class="flex gap-2">
                            <a href="{{ path('app_ressource_show', {'id': ressource.id}) }}" class="flex items-center justify-center p-2 rounded-xl bg-white dark:bg-slate-900 text-slate-900 dark:text-white hover:text-primary border border-slate-200 dark:border-slate-700 hover:border-primary/30 transition-all font-bold group-hover:shadow-sm" title="Voir">
                                {{ ux_icon('heroicons:eye', {class: 'w-5 h-5'}) }}
                            </a>
                            <a href="{{ path('app_ressource_edit', {'id': ressource.id}) }}" class="flex items-center justify-center p-2 rounded-xl bg-white dark:bg-slate-900 text-slate-900 dark:text-white hover:text-amber-500 border border-slate-200 dark:border-slate-700 hover:border-amber-500/30 transition-all font-bold group-hover:shadow-sm" title="Modifier">
                                {{ ux_icon('heroicons:pencil', {class: 'w-5 h-5'}) }}
                            </a>
                        </div>
                        
                        <div class="flex gap-2">
                            {% if ressource.status == 'validated' %}
                            <form method="post" action="{{ path('app_admin_ressource_suspend', {'id': ressource.id}) }}" onsubmit="return confirm('Suspendre cette ressource la cachera du site. Confirmer ?');" class="m-0">
                                <input type="hidden" name="_token" value="{{ csrf_token('suspend' ~ ressource.id) }}">
                                <button class="flex items-center justify-center p-2 rounded-xl bg-white dark:bg-slate-900 text-slate-900 dark:text-white hover:text-orange-500 hover:bg-orange-50 dark:hover:bg-orange-900/40 border border-slate-200 dark:border-slate-700 transition-all group-hover:shadow-sm" title="Suspendre (modération)">
                                    {{ ux_icon('heroicons:pause-circle', {class: 'w-5 h-5'}) }}
                                </button>
                            </form>
                            {% endif %}
                            
                            <form method="post" action="{{ path('app_admin_ressource_delete', {'id': ressource.id}) }}" onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer DÉFINITIVEMENT cette ressource ?');" class="m-0">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ ressource.id) }}">
                                <button class="flex items-center justify-center p-2 rounded-xl bg-rose-50 dark:bg-rose-900/20 text-rose-500 hover:bg-rose-500 hover:text-white border border-rose-200 dark:border-rose-900/50 transition-all group-hover:shadow-sm" title="Supprimer">
                                    {{ ux_icon('heroicons:trash', {class: 'w-5 h-5'}) }}
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="col-span-full py-12 text-center">
                    <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-slate-100 dark:bg-slate-800 text-slate-900 mb-4 dark:text-white">
                        {{ ux_icon('heroicons:document-magnifying-glass', {class: 'w-8 h-8'}) }}
                    </div>
                    <h3 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Aucune ressource trouvée</h3>
                    <p class="text-slate-900 dark:text-white max-w-sm mx-auto">Essayez de modifier vos filtres ou revenez plus tard.</p>
                </div>
            {% endfor %}
        </div>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        if (typeof gsap !== 'undefined') {
            gsap.from(".gsap-stagger-item", {
                y: 30,
                opacity: 0,
                duration: 0.8,
                stagger: 0.1,
                ease: "power3.out",
                clearProps: "all"
            });
        }
    });
</script>
{% endblock %}
