{% extends 'base.html.twig' %}

{% block title %}Explorer les Ressources - (RE)Sources Relationnelles{% endblock %}

{% block body %}
<div class="flex flex-col gap-8 pb-12 w-full max-w-7xl mx-auto">
    
    {# Header Section #}
    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-800 tracking-tight">Explorateur de Ressources</h1>
            <p class="text-slate-500 mt-1">Découvrez, partagez et consultez les ressources de la communauté.</p>
        </div>
        
        <a href="{{ path('app_ressource_new') }}" class="btn-primary flex items-center justify-center gap-2 whitespace-nowrap">
            {{ ux_icon('heroicons:plus-circle', {class: 'w-5 h-5'}) }}
            Créer une ressource
        </a>
    </div>

    {# Ressources Grid #}
    {% if ressources|length > 0 %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            {% for ressource in ressources %}
                <div class="glass-card flex flex-col h-full group">
                    <div class="flex justify-between items-start mb-4">
                        <div class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold bg-indigo-50 text-indigo-700 border border-indigo-100">
                            {{ ux_icon('heroicons:tag', {class: 'w-3.5 h-3.5'}) }}
                            {{ ressource.type ?: 'Général' }}
                        </div>
                        <div class="flex items-center gap-1.5 text-xs font-medium {{ ressource.status ? 'text-emerald-600' : 'text-amber-500' }}">
                            <span class="relative flex h-2 w-2">
                                <span class="{{ ressource.status ? 'bg-emerald-500' : 'bg-amber-400' }} absolute inline-flex h-full w-full rounded-full opacity-75"></span>
                            </span>
                            {{ ressource.status ? 'Publié' : 'Brouillon' }}
                        </div>
                    </div>
                    
                    <h3 class="text-xl font-bold text-slate-800 mb-2 group-hover:text-primary transition-colors line-clamp-2">
                        {{ ressource.title }}
                    </h3>
                    
                    <p class="text-sm text-slate-600 mb-6 flex-grow line-clamp-3">
                        {{ ressource.content }}
                    </p>
                    
                    <div class="mt-auto pt-4 border-t border-slate-100 flex items-center justify-between text-xs text-slate-500">
                        <div class="flex items-center gap-1.5">
                            {{ ux_icon('heroicons:calendar', {class: 'w-4 h-4'}) }}
                            {{ ressource.creationDate ? ressource.creationDate|date('d/m/Y') : 'Non daté' }}
                        </div>
                        
                        <div class="flex items-center gap-2">
                            <a href="{{ path('app_ressource_show', {'id': ressource.id}) }}" class="p-1.5 text-slate-400 hover:text-primary hover:bg-blue-50 rounded-md transition-colors" title="Voir">
                                {{ ux_icon('heroicons:eye', {class: 'w-5 h-5'}) }}
                            </a>
                            <a href="{{ path('app_ressource_edit', {'id': ressource.id}) }}" class="p-1.5 text-slate-400 hover:text-amber-500 hover:bg-amber-50 rounded-md transition-colors" title="Éditer">
                                {{ ux_icon('heroicons:pencil-square', {class: 'w-5 h-5'}) }}
                            </a>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>
    {% else %}
        {# Empty State #}
        <div class="flex flex-col items-center justify-center p-12 text-center glass-card border-dashed border-2 border-slate-200">
            <div class="w-20 h-20 bg-slate-50 rounded-full flex items-center justify-center mb-4">
                {{ ux_icon('heroicons:folder-open', {class: 'w-10 h-10 text-slate-400'}) }}
            </div>
            <h3 class="text-xl font-bold text-slate-800 mb-2">Aucune ressource trouvée</h3>
            <p class="text-slate-500 max-w-md mx-auto mb-6">Il n'y a pas encore de ressources disponibles sur la plateforme. Soyez le premier à partager vos connaissances !</p>
            <a href="{{ path('app_ressource_new') }}" class="btn-primary flex items-center gap-2">
                {{ ux_icon('heroicons:plus', {class: 'w-5 h-5'}) }}
                Créer la première ressource
            </a>
        </div>
    {% endif %}

</div>
{% endblock %}
