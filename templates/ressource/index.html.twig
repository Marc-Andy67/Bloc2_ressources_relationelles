{% extends 'base.html.twig' %}

{% block title %}Explorer les Ressources - (RE)Sources Relationnelles{% endblock %}

{% block body %}
<div class="flex flex-col gap-8 pb-12 w-full max-w-7xl mx-auto">
    
    {# Header Section #}
    <div class="header-section flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 relative z-10" aria-labelledby="page-title">
        <div>
            <h1 id="page-title" class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight will-change-transform">Explorateur de Ressources</h1>
            <p class="text-lg text-slate-900 dark:text-white mt-2 font-medium">Découvrez, partagez et consultez les ressources de la communauté.</p>
        </div>
    </div>

    {% if not app.user %}
    <div role="alert" class="gsap-alert flex items-start sm:items-center gap-4 p-5 rounded-2xl bg-blue-50/80 dark:bg-blue-900/30 border border-blue-200/60 dark:border-blue-800/60 backdrop-blur-md shadow-sm">
        {{ ux_icon('heroicons:information-circle', {class: 'w-6 h-6 shrink-0 text-blue-500 dark:text-blue-400 mt-0.5 sm:mt-0', 'aria-hidden': 'true'}) }}
        <span class="text-sm sm:text-base text-blue-800 dark:text-blue-100">
            Vous consultez (RE)Sources en tant que visiteur. 
            <a href="{{ path('app_login') }}" class="font-bold underline decoration-blue-300 dark:decoration-blue-700 underline-offset-4 hover:text-blue-600 dark:hover:text-blue-300 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-cta rounded-sm">Connectez-vous</a> ou 
            <a href="{{ path('app_register') }}" class="font-bold underline decoration-blue-300 dark:decoration-blue-700 underline-offset-4 hover:text-blue-600 dark:hover:text-blue-300 transition-colors focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-cta rounded-sm">inscrivez-vous</a> pour aimer, sauvegarder et publier des ressources.
        </span>
    </div>
    {% endif %}

    {# Section Filtres #}
    <div class="filter-section glass-card mb-2 z-20">
        <form method="get" action="{{ path('app_ressource_index') }}" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-5 items-end" role="search" aria-label="Filtrer les ressources">
            <div class="filter-item">
                <label for="author" class="form-label">Auteur</label>
                <input type="text" name="author" id="author" value="{{ currentFilters.author|default('') }}" placeholder="Nom complet ou email" class="input-field" aria-label="Filtrer par auteur">
            </div>
            <div class="filter-item">
                <label for="category" class="form-label">Catégorie</label>
                <select name="category" id="category" class="input-field cursor-pointer dark:bg-slate-800" aria-label="Filtrer par catégorie">
                    <option value="">Toutes</option>
                    {% for cat in categories %}
                        <option value="{{ cat.id }}" {{ currentFilters.category|default('') == cat.id ? 'selected' : '' }}>{{ cat.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="filter-item">
                <label for="relation" class="form-label">Type de relations</label>
                <select name="relation" id="relation" class="input-field cursor-pointer dark:bg-slate-800" aria-label="Filtrer par type de relation">
                    <option value="">Tous</option>
                    {% for rel in relationTypes %}
                        <option value="{{ rel.id }}" {{ currentFilters.relation|default('') == rel.id ? 'selected' : '' }}>{{ rel.name }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="filter-item">
                <label for="type" class="form-label">Type de ressource</label>
                <select name="type" id="type" class="input-field cursor-pointer dark:bg-slate-800" aria-label="Filtrer par type de ressource">
                    <option value="">Tous</option>
                    {% for t in types %}
                        <option value="{{ t }}" {{ currentFilters.type|default('') == t ? 'selected' : '' }}>{{ t|split('/')|last|upper }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="filter-action flex gap-3">
                <button type="submit" class="btn-primary w-full shadow-lg hover:shadow-xl focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-cta" aria-label="Appliquer les filtres">
                    {{ ux_icon('heroicons:funnel', {class: 'w-5 h-5', 'aria-hidden': 'true'}) }} Filtrer
                </button>
                <a href="{{ path('app_ressource_index') }}" class="btn-secondary px-4 backdrop-blur-md focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-cta" title="Réinitialiser les filtres" aria-label="Réinitialiser les filtres">
                    {{ ux_icon('heroicons:x-mark', {class: 'w-5 h-5', 'aria-hidden': 'true'}) }}
                </a>
            </div>
        </form>
    </div>

    {# Ressources Grid (Isometric capable via CSS if needed) #}
    {% if ressources|length > 0 %}
        <div class="isometric-grid grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 relative z-10 pt-4" aria-live="polite" aria-atomic="true">
            <span class="sr-only">{{ ressources|length }} ressources trouvées.</span>
            {% for ressource in ressources %}
                <article class="isometric-item glass-card flex flex-col h-full group focus-within:ring-4 focus-within:ring-cta transition-shadow duration-300 rounded-2xl">
                    <div class="flex justify-between items-start mb-5 relative z-10">
                        <div class="flex flex-wrap items-center gap-2" aria-label="Métadonnées de la ressource">
                            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-indigo-50/80 dark:bg-indigo-500/10 text-indigo-700 dark:text-indigo-300 border border-indigo-200/50 dark:border-indigo-500/30 backdrop-blur-sm shadow-sm transition-transform group-hover:scale-105" aria-label="Catégorie: {{ ressource.category ? ressource.category.name : 'Général' }}">
                                {{ ux_icon('heroicons:folder', {class: 'w-4 h-4', 'aria-hidden': 'true'}) }}
                                {{ ressource.category ? ressource.category.name : 'Général' }}
                            </span>
                            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-slate-100/80 dark:bg-slate-700/50 text-slate-900 dark:text-white border border-slate-200/50 dark:border-slate-600/50 backdrop-blur-sm shadow-sm transition-transform group-hover:scale-105 group-hover:delay-75" title="Type de contenu" aria-label="Type: {{ ressource.type ? ressource.type|split('/')|last|upper : 'TEXTE' }}">
                                {{ ux_icon('heroicons:document-text', {class: 'w-4 h-4', 'aria-hidden': 'true'}) }}
                                {{ ressource.type ? ressource.type|split('/')|last|upper : 'TEXTE' }}
                            </span>
                        </div>
                        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold {{ ressource.status ? 'bg-emerald-50/80 dark:bg-emerald-500/10 text-emerald-700 dark:text-emerald-400 border border-emerald-200/50 dark:border-emerald-500/30' : 'bg-amber-50/80 dark:bg-amber-500/10 text-amber-700 dark:text-amber-400 border border-amber-200/50 dark:border-amber-500/30' }} backdrop-blur-sm shadow-sm transition-transform group-hover:scale-105 group-hover:delay-100" aria-label="Statut: {{ ressource.status ? 'Publié' : 'Brouillon' }}">
                            <span class="relative flex h-2 w-2" aria-hidden="true">
                                <span class="{{ ressource.status ? 'bg-emerald-500' : 'bg-amber-400' }} animate-ping absolute inline-flex h-full w-full rounded-full opacity-50"></span>
                                <span class="{{ ressource.status ? 'bg-emerald-500' : 'bg-amber-500' }} relative inline-flex rounded-full h-2 w-2"></span>
                            </span>
                            {{ ressource.status ? 'Publié' : 'Brouillon' }}
                        </span>
                    </div>
                    
                    <a href="{{ path('app_ressource_show', {'id': ressource.id}) }}" class="block group/link flex-grow cursor-pointer my-2 relative z-10 focus:outline-none" aria-label="Lire la ressource: {{ ressource.title }}">
                        <h3 class="text-2xl font-bold text-slate-900 dark:text-white mb-3 group-hover/link:text-primary dark:group-hover/link:text-blue-400 transition-colors line-clamp-2 leading-tight">
                            {{ ressource.title }}
                        </h3>
                        
                        {% if ressource.relationTypes|length > 0 %}
                            <div class="flex flex-wrap gap-2 mb-4" aria-label="Types de relations concernés">
                                {% for relation in ressource.relationTypes %}
                                    <span class="px-2.5 py-1 bg-white/60 dark:bg-slate-800/60 text-slate-900 dark:text-white text-xs font-bold rounded-lg border border-slate-200/60 dark:border-slate-700/60 shadow-sm">
                                        {{ relation.name }}
                                    </span>
                                {% endfor %}
                            </div>
                        {% endif %}
                        
                        <p class="text-sm md:text-base text-slate-900 dark:text-white mb-6 line-clamp-3 leading-relaxed transition-colors group-hover/link:text-slate-900 dark:group-hover/link:text-slate-100 font-medium">
                            {{ ressource.content }}
                        </p>
                    </a>
                    
                    <div class="mt-auto pt-5 border-t border-slate-200/50 dark:border-slate-700/50 flex items-center justify-between text-xs text-slate-900 dark:text-white relative z-10 w-full font-bold">
                        <div class="flex items-center gap-2 flex-wrap" aria-label="Informations de publication">
                            <span class="flex items-center gap-1.5 bg-slate-100/50 dark:bg-slate-800/50 px-2.5 py-1.5 rounded-lg border border-slate-200/60 dark:border-slate-700/60" aria-label="Date de création: {{ ressource.creationDate ? ressource.creationDate|date('d/m/Y') : 'Inconnue' }}">
                                {{ ux_icon('heroicons:calendar', {class: 'w-4 h-4', 'aria-hidden': 'true'}) }}
                                {{ ressource.creationDate ? ressource.creationDate|date('d/m/Y') : '-' }}
                            </span>
                            <span class="flex items-center gap-1.5 bg-slate-100/50 dark:bg-slate-800/50 px-2.5 py-1.5 rounded-lg border border-slate-200/60 dark:border-slate-700/60 max-w-[120px]" title="{{ ressource.author ? ressource.author.email : 'Anonyme' }}" aria-label="Auteur: {{ ressource.author ? ressource.author.email|split('@')[0]|capitalize : 'Anonyme' }}">
                                {{ ux_icon('heroicons:user', {class: 'w-4 h-4', 'aria-hidden': 'true'}) }}
                                <span class="truncate">{{ ressource.author ? ressource.author.email|split('@')[0]|capitalize : 'Anonyme' }}</span>
                            </span>
                        </div>
                        
                        <div class="flex items-center gap-1.5">
                            <a href="{{ path('app_ressource_show', {'id': ressource.id}) }}" class="p-2 text-slate-900 hover:text-primary dark:hover:text-blue-400 hover:bg-blue-50 dark:hover:bg-blue-900/30 rounded-xl transition-all hover:scale-110 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-cta dark:text-white" aria-label="Voir les détails de la ressource {{ ressource.title }}">
                                {{ ux_icon('heroicons:eye', {class: 'w-5 h-5', 'aria-hidden': 'true'}) }}
                            </a>
                            {% if app.user %}
                            <a href="{{ path('app_ressource_edit', {'id': ressource.id}) }}" class="p-2 text-slate-900 hover:text-amber-500 dark:hover:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-900/30 rounded-xl transition-all hover:scale-110 focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-cta dark:text-white" aria-label="Éditer la ressource {{ ressource.title }}">
                                {{ ux_icon('heroicons:pencil-square', {class: 'w-5 h-5', 'aria-hidden': 'true'}) }}
                            </a>
                            {% endif %}
                        </div>
                    </div>
                </article>
            {% endfor %}
        </div>
    {% else %}
        {# Empty State (Spatial Depth focused) #}
        <div class="gsap-empty-state flex flex-col items-center justify-center p-16 text-center glass-card border-dashed border-2 border-slate-300 dark:border-slate-700/50 mt-8 group hover:border-primary/50 dark:hover:border-blue-500/50 transition-colors" role="status" aria-live="polite">
            <div class="w-24 h-24 bg-white/50 dark:bg-slate-800/50 backdrop-blur-md rounded-3xl flex items-center justify-center mb-6 shadow-lg border border-white/40 dark:border-slate-700/50 group-hover:scale-110 group-hover:-translate-y-2 transition-all duration-500" aria-hidden="true">
                {{ ux_icon('heroicons:folder-open', {class: 'w-12 h-12 text-slate-900 dark:text-white group-hover:text-primary dark:group-hover:text-blue-400 transition-colors'}) }}
            </div>
            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-3">Aucune ressource trouvée</h2>
            <p class="text-slate-900 dark:text-white text-lg max-w-lg mx-auto mb-8 font-medium">Il n'y a pas encore de connaissances partagées ici. Aidez-nous à construire la plateforme !</p>
            {% if app.user %}
            <a href="{{ path('app_ressource_new') }}" class="btn-primary flex items-center gap-2 text-lg focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-cta">
                {{ ux_icon('heroicons:plus-circle', {class: 'w-6 h-6', 'aria-hidden': 'true'}) }}
                Créer la première ressource
            </a>
            {% else %}
            <a href="{{ path('app_register') }}" class="btn-primary flex items-center gap-2 text-lg focus-visible:outline-none focus-visible:ring-4 focus-visible:ring-cta">
                {{ ux_icon('heroicons:user-plus', {class: 'w-6 h-6', 'aria-hidden': 'true'}) }}
                Créer un compte pour publier
            </a>
            {% endif %}
        </div>
    {% endif %}

</div>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        // Only run animations if user doesn't prefer reduced motion
        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion) return;

        // Header entrance
        gsap.from(".header-section", {
            y: 30,
            opacity: 0,
            duration: 0.8,
            ease: "power3.out"
        });

        // Filter panel entrance
        gsap.from(".filter-section", {
            y: 40,
            opacity: 0,
            duration: 0.8,
            delay: 0.2,
            ease: "power3.out"
        });
        
        gsap.from(".filter-item, .filter-action", {
            y: 20,
            opacity: 0,
            duration: 0.6,
            delay: 0.4,
            stagger: 0.05,
            ease: "back.out(1.2)"
        });

        // Staggered Cards Entrance (Dominoes effect from Antigravity Guidelines)
        gsap.from(".isometric-item", {
            scrollTrigger: {
                trigger: ".isometric-grid",
                start: "top 85%"
            },
            y: 80,
            rotationX: 10,
            opacity: 0,
            duration: 0.8,
            stagger: 0.1,
            ease: "back.out(1.2)"
        });

        // Empty state bouncy entrance
        gsap.from(".gsap-empty-state", {
            scale: 0.9,
            y: 30,
            opacity: 0,
            duration: 0.6,
            delay: 0.3,
            ease: "back.out(1.5)"
        });
    });
</script>
{% endblock %}
