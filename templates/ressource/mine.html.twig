{% extends 'base.html.twig' %}

{% block title %}Mes publications — (RE)Sources Relationnelles{% endblock %}

{% block body %}
<div class="px-4 md:px-8 py-8 md:py-12 max-w-7xl mx-auto">
    <div class="flex justify-between items-end mb-8 border-b border-slate-200 dark:border-slate-700 pb-4">
        <div>
            <h1 class="text-3xl md:text-4xl font-extrabold text-slate-900 mb-4 tracking-tight dark:text-white">Mes publications</h1>
            <p class="text-lg text-slate-900 max-w-2xl dark:text-white">Retrouvez ici toutes les ressources que vous avez créées et partagées avec la communauté.</p>
        </div>
        <a href="{{ path('app_ressource_index') }}" class="btn-primary text-sm">Explorer d'autres contenus</a>
    </div>

    {% if ressources is empty %}
        <div class="glass-card flex flex-col items-center justify-center p-16 text-center border border-dashed border-slate-300 dark:border-slate-700">
            <div class="w-20 h-20 bg-slate-50 dark:bg-slate-800 rounded-full flex items-center justify-center mb-4 text-slate-900 dark:text-white">
                {{ ux_icon('heroicons:bookmark', {class: 'w-10 h-10'}) }}
            </div>
            <h3 class="text-xl font-bold text-slate-900 mb-2 dark:text-white">Vous n'avez pas encore publié de ressource</h3>
            <p class="text-slate-900 max-w-md mx-auto mb-6 dark:text-white">Partagez votre expérience et vos connaissances avec la communauté en créant votre première ressource.</p>
            <a href="{{ path('app_ressource_new') }}" class="btn-primary inline-flex items-center gap-2">
                {{ ux_icon('heroicons:plus', {class: 'w-5 h-5'}) }}
                Créer une ressource
            </a>
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for ressource in ressources %}
                <article class="glass-card group hover:-translate-y-1 hover:shadow-xl transition-all duration-300 flex flex-col h-full border border-slate-200/60 dark:border-slate-700/60 focus-within:ring-4 focus-within:ring-amber-500/50 pt-8 mt-2">
                    <div class="absolute top-0 left-0 right-0 h-2 bg-gradient-to-r from-amber-400 to-amber-500 dark:from-amber-600 dark:to-amber-800 w-full z-0"></div>
                    <div class="flex-grow flex flex-col relative z-10">
                        <div class="flex justify-between items-start mb-5">
                            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-amber-50 dark:bg-amber-500/10 text-amber-700 dark:text-amber-300 border border-amber-200/50 dark:border-amber-500/30 shadow-sm transition-transform hover:scale-105">
                                {{ ux_icon('heroicons:tag', {class: 'w-4 h-4'}) }}
                                {{ ressource.category ? ressource.category.name : 'Général' }}
                            </span>
                            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-amber-50 dark:bg-amber-500/10 text-amber-700 dark:text-amber-300 border border-amber-200/50 dark:border-amber-500/30 shadow-sm transition-transform hover:scale-105">
                                {{ ux_icon('heroicons:bookmark', {class: 'w-4 h-4 fill-amber-500 dark:fill-amber-400'}) }} Sauvegardée
                            </span>
                        </div>
                        
                        <a href="{{ path('app_ressource_show', {'id': ressource.id}) }}" class="block group/link flex-grow cursor-pointer my-2 focus:outline-none">
                            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-3 group-hover/link:text-amber-600 dark:group-hover/link:text-amber-400 transition-colors line-clamp-2 leading-tight">
                                {{ ressource.title }}
                            </h2>
                            <p class="text-sm md:text-base text-slate-900 dark:text-white mb-6 line-clamp-3 leading-relaxed font-medium transition-colors">
                                {{ ressource.content|striptags }}
                            </p>
                        </a>
                        
                        <div class="flex items-center justify-between mt-auto pt-5 border-t border-slate-200/50 dark:border-slate-700/50 font-bold">
                            <div class="flex items-center gap-2 text-xs text-slate-900 dark:text-white">
                                <span class="flex items-center gap-1.5 bg-slate-100/50 dark:bg-slate-800/50 px-2.5 py-1.5 rounded-lg border border-slate-200/60 dark:border-slate-700/60">
                                    {{ ux_icon('heroicons:user', {class: 'w-4 h-4'}) }}
                                    <span class="truncate">{{ ressource.author.email|split('@')[0]|capitalize }}</span>
                                </span>
                            </div>
                            
                            <a href="{{ path('app_ressource_show', {'id': ressource.id}) }}" class="p-2 text-slate-900 dark:text-white hover:text-amber-600 dark:hover:text-amber-400 hover:bg-amber-50 dark:hover:bg-amber-900/40 rounded-xl transition-all hover:scale-110 focus:outline-none focus-visible:ring-4 focus-visible:ring-amber-500/50" title="Voir la ressource">
                                {{ ux_icon('heroicons:arrow-right', {class: 'w-5 h-5'}) }}
                            </a>
                        </div>
                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
