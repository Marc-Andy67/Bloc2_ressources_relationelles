{% extends 'base.html.twig' %}

{% block title %}Mes Ressources Favorites - (RE)Sources Relationnelles{% endblock %}

{% block body %}
<div class="px-4 md:px-8 py-8 md:py-12 max-w-7xl mx-auto">
    <div class="flex justify-between items-end mb-8 border-b border-slate-200 dark:border-slate-700 pb-4">
        <div>
            <h1 class="text-3xl font-extrabold text-slate-900 dark:text-white tracking-tight flex items-center gap-3">
                {{ ux_icon('heroicons:heart', {class: 'w-8 h-8 text-red-500'}) }}
                Mes Favoris
            </h1>
            <p class="text-slate-900 dark:text-white mt-2">Les ressources que vous avez aimées et que vous soutenez.</p>
        </div>
        <a href="{{ path('app_ressource_index') }}" class="btn-primary text-sm">Explorer d'autres contenus</a>
    </div>

    {% if ressources is empty %}
        <div class="glass-card flex flex-col items-center justify-center p-16 text-center border border-dashed border-slate-300 dark:border-slate-700">
            <div class="w-20 h-20 bg-slate-50 dark:bg-slate-800 rounded-full flex items-center justify-center mb-4 text-slate-900 dark:text-white">
                {{ ux_icon('heroicons:heart', {class: 'w-10 h-10'}) }}
            </div>
            <h2 class="text-xl font-bold text-slate-900 dark:text-white mb-2">Aucun favori pour le moment</h2>
            <p class="text-slate-900 dark:text-white max-w-md mx-auto mb-6">
                Montrez votre soutien aux créateurs en mettant des ressources en favori lors de votre navigation.
            </p>
            <a href="{{ path('app_ressource_index') }}" class="btn-primary flex items-center gap-2">
                {{ ux_icon('heroicons:magnifying-glass', {class: 'w-5 h-5'}) }}
                Parcourir les ressources
            </a>
        </div>
    {% else %}
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
            {% for ressource in ressources %}
                <article class="glass-card group hover:-translate-y-1 hover:shadow-xl transition-all duration-300 flex flex-col h-full border border-slate-200/60 dark:border-slate-700/60 focus-within:ring-4 focus-within:ring-red-500/50 pt-8 mt-2">
                    <div class="absolute top-0 left-0 right-0 h-2 bg-gradient-to-r from-red-400 to-red-500 dark:from-red-600 dark:to-red-800 w-full z-0"></div>
                    <div class="flex-grow flex flex-col relative z-10">
                        <div class="flex justify-between items-start mb-5">
                            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-primary/10 dark:bg-blue-500/10 text-primary dark:text-blue-300 border border-transparent dark:border-blue-500/30 shadow-sm transition-transform hover:scale-105">
                                {{ ux_icon('heroicons:tag', {class: 'w-4 h-4'}) }}
                                {{ ressource.category ? ressource.category.name : 'Général' }}
                            </span>
                            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-full text-xs font-bold bg-red-50 dark:bg-red-500/10 text-red-600 dark:text-red-400 border border-red-200/50 dark:border-red-500/30 shadow-sm transition-transform hover:scale-105">
                                {{ ux_icon('heroicons:heart', {class: 'w-4 h-4 fill-red-500 dark:fill-red-400'}) }} Favori
                            </span>
                        </div>
                        
                        <a href="{{ path('app_ressource_show', {'id': ressource.id}) }}" class="block group/link flex-grow cursor-pointer my-2 focus:outline-none">
                            <h2 class="text-2xl font-bold text-slate-900 dark:text-white mb-3 group-hover/link:text-primary dark:group-hover/link:text-blue-400 transition-colors line-clamp-2 leading-tight">
                                {{ ressource.title }}
                            </h2>
                            <p class="text-sm md:text-base text-slate-900 dark:text-white mb-6 line-clamp-3 leading-relaxed font-medium transition-colors">
                                {{ ressource.content|striptags }}
                            </p>
                        </a>
                        
                        <div class="flex items-center justify-between mt-auto pt-5 border-t border-slate-200/50 dark:border-slate-700/50 font-bold">
                            <div class="flex items-center gap-2 text-xs text-slate-900 dark:text-white">
                                <span class="flex items-center gap-1.5 bg-slate-100/50 dark:bg-slate-800/50 px-2.5 py-1.5 rounded-lg border border-slate-200/60 dark:border-slate-700/60">
                                    {{ ux_icon('heroicons:user', {class: 'w-4 h-4'}) }}
                                    <span class="truncate">{{ ressource.author.email|split('@')[0]|capitalize }}</span>
                                </span>
                            </div>
                            
                            <a href="{{ path('app_ressource_show', {'id': ressource.id}) }}" class="p-2 text-slate-900 dark:text-white hover:text-red-600 dark:hover:text-red-400 hover:bg-red-50 dark:hover:bg-red-900/40 rounded-xl transition-all hover:scale-110 focus:outline-none focus-visible:ring-4 focus-visible:ring-red-500/50" title="Voir la ressource">
                                {{ ux_icon('heroicons:arrow-right', {class: 'w-5 h-5'}) }}
                            </a>
                        </div>
                    </div>
                </article>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}
