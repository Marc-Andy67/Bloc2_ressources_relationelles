{% extends 'base.html.twig' %}

{% block title %}Progression index{% endblock %}

{% block body %}
    <div class="header-section flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 relative z-10 mb-8" aria-labelledby="page-title">
        <div>
            <h1 id="page-title" class="text-4xl md:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight will-change-transform">Ma Progression</h1>
            <p class="text-lg text-slate-900 dark:text-white mt-2 font-medium">Historique de mon activité et statistiques d'engagement.</p>
        </div>
        <div class="shrink-0">
            <a href="{{ path('app_progression_new') }}" class="btn-primary flex items-center gap-2">
                {{ ux_icon('heroicons:plus', {class: 'w-5 h-5'}) }} Nouvelle Session
            </a>
        </div>
    </div>

    <div class="glass-card overflow-x-auto w-full">
        <table class="w-full text-left border-collapse">
            <thead>
                <tr class="border-b border-slate-200 dark:border-slate-700 text-slate-900 dark:text-white text-sm font-semibold uppercase tracking-wider">
                    <th class="py-4 px-4 font-bold text-left">#</th>
                    <th class="py-4 px-4 font-bold text-left">Description</th>
                    <th class="py-4 px-4 font-bold text-left">Date</th>
                    <th class="py-4 px-4 font-bold text-right">Actions</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100 dark:divide-slate-800">
            {% for progression in progressions %}
                <tr class="hover:bg-slate-50/50 dark:hover:bg-slate-800/30 transition-colors">
                    <td class="py-4 px-4 font-medium text-slate-900 dark:text-white">#{{ progression.id }}</td>
                    <td class="py-4 px-4 text-slate-900 dark:text-white">{{ progression.description }}</td>
                    <td class="py-4 px-4 text-slate-900 dark:text-white">{{ progression.date ? progression.date|date('Y-m-d') : '' }}</td>
                    <td class="py-4 px-4 text-right">
                        <div class="flex items-center justify-end gap-2">
                            <a href="{{ path('app_progression_show', {'id': progression.id}) }}" class="p-2 text-slate-900 hover:text-primary dark:hover:text-blue-400 transition-colors rounded-lg hover:bg-slate-100 dark:hover:bg-slate-800 dark:text-white" aria-label="Voir">
                                {{ ux_icon('heroicons:eye', {class: 'w-5 h-5'}) }}
                            </a>
                            <a href="{{ path('app_progression_edit', {'id': progression.id}) }}" class="p-2 text-slate-900 hover:text-amber-500 transition-colors rounded-lg hover:bg-amber-50 dark:hover:bg-amber-900/40 dark:text-white" aria-label="Modifier">
                                {{ ux_icon('heroicons:pencil', {class: 'w-5 h-5'}) }}
                            </a>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="4" class="py-12 text-center text-slate-900 dark:text-white font-medium">Aucune donnée de progression trouvée.</td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
