{% extends 'base.html.twig' %}

{% block title %}Ma Progression - (RE)Sources Relationnelles{% endblock %}

{% block body %}
<div class="px-4 md:px-8 py-8 md:py-12 max-w-7xl mx-auto flex flex-col gap-10">

    {# Header #}
    <div class="border-b border-slate-200 pb-6">
        <h1 class="text-3xl font-extrabold text-slate-900 tracking-tight flex items-center gap-3 dark:text-white">
            {{ ux_icon('heroicons:chart-bar', {class: 'w-8 h-8 text-emerald-500'}) }}
            Ma Progression
        </h1>
        <p class="text-slate-900 mt-2 dark:text-white">Votre tableau de bord personnel : statistiques et activité récente.</p>
    </div>

    {# Stats Cards #}
    <div class="grid grid-cols-2 lg:grid-cols-3 xl:grid-cols-6 gap-4">
        
        <div class="glass-card flex flex-col items-center justify-center p-5 text-center gap-2 border border-blue-100 dark:border-blue-900/30">
            <div class="w-10 h-10 bg-blue-50 dark:bg-blue-900/40 rounded-full flex items-center justify-center">
                {{ ux_icon('heroicons:document-text', {class: 'w-5 h-5 text-blue-600 dark:text-blue-400'}) }}
            </div>
            <div>
                <div class="text-2xl font-extrabold text-blue-600 dark:text-blue-400">{{ published_count }}</div>
                <div class="text-[11px] uppercase tracking-wider font-bold text-slate-500 mt-1 dark:text-slate-400">Ressources publiées</div>
            </div>
        </div>

        <div class="glass-card flex flex-col items-center justify-center p-5 text-center gap-2 border border-emerald-100 dark:border-emerald-900/30">
            <div class="w-10 h-10 bg-emerald-50 dark:bg-emerald-900/40 rounded-full flex items-center justify-center">
                {{ ux_icon('heroicons:book-open', {class: 'w-5 h-5 text-emerald-600 dark:text-emerald-400'}) }}
            </div>
            <div>
                <div class="text-2xl font-extrabold text-emerald-600 dark:text-emerald-400">{{ resources_read }}</div>
                <div class="text-[11px] uppercase tracking-wider font-bold text-slate-500 mt-1 dark:text-slate-400">Ressources consultées</div>
            </div>
        </div>

        <div class="glass-card flex flex-col items-center justify-center p-5 text-center gap-2 border border-fuchsia-100 dark:border-fuchsia-900/30">
            <div class="w-10 h-10 bg-fuchsia-50 dark:bg-fuchsia-900/40 rounded-full flex items-center justify-center">
                {{ ux_icon('heroicons:chat-bubble-left-ellipsis', {class: 'w-5 h-5 text-fuchsia-600 dark:text-fuchsia-400'}) }}
            </div>
            <div>
                <div class="text-2xl font-extrabold text-fuchsia-600 dark:text-fuchsia-400">{{ comment_count }}</div>
                <div class="text-[11px] uppercase tracking-wider font-bold text-slate-500 mt-1 dark:text-slate-400">Commentaires écrits</div>
            </div>
        </div>

        <div class="glass-card flex flex-col items-center justify-center p-5 text-center gap-2 border border-red-100 dark:border-red-900/30">
            <div class="w-10 h-10 bg-red-50 dark:bg-red-900/40 rounded-full flex items-center justify-center">
                {{ ux_icon('heroicons:heart', {class: 'w-5 h-5 text-red-500 dark:text-red-400'}) }}
            </div>
            <div>
                <div class="text-2xl font-extrabold text-red-500 dark:text-red-400">{{ favorites_count }}</div>
                <div class="text-[11px] uppercase tracking-wider font-bold text-slate-500 mt-1 dark:text-slate-400">Favoris</div>
            </div>
        </div>

        <div class="glass-card flex flex-col items-center justify-center p-5 text-center gap-2 border border-amber-100 dark:border-amber-900/30">
            <div class="w-10 h-10 bg-amber-50 dark:bg-amber-900/40 rounded-full flex items-center justify-center">
                {{ ux_icon('heroicons:bookmark', {class: 'w-5 h-5 text-amber-500 dark:text-amber-400'}) }}
            </div>
            <div>
                <div class="text-2xl font-extrabold text-amber-500 dark:text-amber-400">{{ saved_count }}</div>
                <div class="text-[11px] uppercase tracking-wider font-bold text-slate-500 mt-1 dark:text-slate-400">Mis de côté</div>
            </div>
        </div>

        <div class="glass-card flex flex-col items-center justify-center p-5 text-center gap-2 border border-violet-100 dark:border-violet-900/30">
            <div class="w-10 h-10 bg-violet-50 dark:bg-violet-900/40 rounded-full flex items-center justify-center">
                {{ ux_icon('heroicons:hand-thumb-up', {class: 'w-5 h-5 text-violet-500 dark:text-violet-400'}) }}
            </div>
            <div>
                <div class="text-2xl font-extrabold text-violet-500 dark:text-violet-400">{{ liked_count }}</div>
                <div class="text-[11px] uppercase tracking-wider font-bold text-slate-500 mt-1 dark:text-slate-400">Likées</div>
            </div>
        </div>
    </div>

    {# Activité récente #}
    <div class="glass-card p-6 border border-slate-200/60 dark:border-slate-800">
        <h2 class="text-xl font-bold text-slate-900 mb-6 flex items-center gap-2 dark:text-white">
            {{ ux_icon('heroicons:queue-list', {class: 'w-5 h-5 text-slate-500'}) }}
            Journal des interactions
        </h2>

        {% if progressions is empty %}
            <div class="flex flex-col items-center justify-center py-10 text-center">
                <div class="w-16 h-16 bg-slate-50 dark:bg-slate-800 rounded-full flex items-center justify-center mb-3">
                    {{ ux_icon('heroicons:inbox', {class: 'w-8 h-8 text-slate-400'}) }}
                </div>
                <p class="text-slate-900 text-sm dark:text-slate-300">Aucune activité enregistrée pour le moment.</p>
                <a href="{{ path('app_ressource_index') }}" class="mt-4 btn-primary text-sm">Explorer des ressources</a>
            </div>
        {% else %}
            <div class="relative pl-4 border-l-2 border-slate-100 dark:border-slate-800 space-y-8 mt-4">
                {% for progression in progressions %}
                    {# Détermination de l'icône et de la couleur en fonction de l'action #}
                    {% set iconConfig = {
                        'A ajouté aux favoris': { icon: 'heart', color: 'text-red-500', bg: 'bg-red-50 dark:bg-red-900/30' },
                        'A retiré des favoris': { icon: 'x-mark', color: 'text-slate-400', bg: 'bg-slate-50 dark:bg-slate-800' },
                        'A mis de côté': { icon: 'bookmark', color: 'text-amber-500', bg: 'bg-amber-50 dark:bg-amber-900/30' },
                        'A retiré de ses ressources sauvegardées': { icon: 'x-mark', color: 'text-slate-400', bg: 'bg-slate-50 dark:bg-slate-800' },
                        'A aimé la ressource': { icon: 'hand-thumb-up', color: 'text-violet-500', bg: 'bg-violet-50 dark:bg-violet-900/30' },
                        'N\'aime plus la ressource': { icon: 'x-mark', color: 'text-slate-400', bg: 'bg-slate-50 dark:bg-slate-800' },
                        'A publié une nouvelle ressource': { icon: 'document-text', color: 'text-blue-500', bg: 'bg-blue-50 dark:bg-blue-900/30' },
                        'A commenté la ressource': { icon: 'chat-bubble-left', color: 'text-fuchsia-500', bg: 'bg-fuchsia-50 dark:bg-fuchsia-900/30' },
                        'A consulté la ressource': { icon: 'eye', color: 'text-emerald-500', bg: 'bg-emerald-50 dark:bg-emerald-900/30' }
                    } %}
                    
                    {% set actionData = iconConfig[progression.description] ?? { icon: 'bolt', color: 'text-slate-500', bg: 'bg-slate-100 dark:bg-slate-800' } %}

                    <div class="relative flex items-start gap-4">
                        {# Point sur la timeline #}
                        <div class="absolute -left-[25px] flex h-6 w-6 items-center justify-center rounded-full bg-white dark:bg-slate-900 ring-4 ring-white dark:ring-slate-900">
                            <span class="h-2.5 w-2.5 rounded-full {{ actionData.color|replace({'text-': 'bg-'}) }}"></span>
                        </div>
                        
                        {# Activity Card #}
                        <div class="flex-grow glass-card flex items-stretch border border-slate-100/60 dark:border-slate-800/60 rounded-xl overflow-hidden hover:shadow-md transition-shadow group">
                            {# Icon Area #}
                            <div class="w-14 flex items-center justify-center shrink-0 {{ actionData.bg }}">
                                {{ ux_icon('heroicons:' ~ actionData.icon, {class: 'w-6 h-6 ' ~ actionData.color}) }}
                            </div>
                            
                            {# Content #}
                            <div class="p-3 flex-grow flex flex-col justify-center">
                                <span class="text-xs font-bold text-slate-500 dark:text-slate-400 uppercase tracking-wide mb-1 flex items-center gap-2">
                                    {{ progression.description }}
                                    <span class="lowercase font-normal text-slate-400">• {{ progression.date ? progression.date|date('d/m/Y') : '—' }}</span>
                                </span>
                                <h3 class="text-sm font-bold text-slate-900 dark:text-white line-clamp-1">
                                    {{ progression.ressource ? progression.ressource.title : 'Ressource introuvable' }}
                                </h3>
                            </div>
                            
                            {# Action #}
                            {% if progression.ressource %}
                            <div class="flex items-center justify-center pr-4 pl-2 opacity-0 group-hover:opacity-100 transition-opacity">
                                <a href="{{ path('app_ressource_show', {'id': progression.ressource.id}) }}" class="p-2 bg-slate-100 dark:bg-slate-800 hover:bg-slate-200 dark:hover:bg-slate-700 rounded-full text-slate-700 dark:text-slate-300 transition-colors" title="Aller à la ressource">
                                    {{ ux_icon('heroicons:chevron-right', {class: 'w-4 h-4'}) }}
                                </a>
                            </div>
                            {% endif %}
                        </div>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>

</div>
{% endblock %}
